# ─── Core ───────────────────────────────────────────────
# Port the Node server listens on (reverse proxy / firewall should forward 80/443 → this)
PORT=3000

# Production flag. Set to "production" on the server.
# When "production": view cache ON, secure cookies (if HTTPS), verbose file logging ON.
NODE_ENV=development

# ─── Security ───────────────────────────────────────────
# REQUIRED in production. Use a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed browser origins for CORS.
# On the public site this is usually just your domain(s).
# Use "*" only for local/dev. Example: https://nady.example.com,https://www.example.com
CORS_ORIGIN=*

# ─── HTTPS / Proxy ────────────────────────────────────
# Set to "true" if a reverse proxy (nginx, Cloudflare, etc.) terminates TLS
# and sets X-Forwarded-* headers. Enables secure cookies + proxy trust.
HTTPS=true

# OPTIONAL direct TLS: if you want the Node process to serve HTTPS itself
# (instead of a proxy), set HTTPS_DIRECT=true and provide the two paths below.
HTTPS_DIRECT=false
TLS_KEY_PATH=
TLS_CERT_PATH=

# ─── Database ──────────────────────────────────────────
# Path is relative to the project root. Keep inside the project for easy backups.
DB_PATH=./data/club.db

# ─── Uploads ──────────────────────────────────────────
UPLOAD_PATH=./uploads
# Max upload size in bytes (5 MB default). Raise cautiously.
MAX_FILE_SIZE=5242880

# ─── Logging ──────────────────────────────────────────
# One of: error, warn, info, debug
LOG_LEVEL=info
# Directory for log files (created automatically).
LOG_DIR=./logs
