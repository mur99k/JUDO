# ─── Core ───────────────────────────────────────
# Port the Node server listens on (reverse proxy / firewall should forward 80/443 → this)
PORT=3000

# Production flag. Set to "production" on the server.
# When "production": view cache ON, secure cookies (if HTTPS), verbose file logging ON.
NODE_ENV=development

# ─── Security ───────────────────────────────────
# REQUIRED in production. Use a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed browser origins for CORS.
# On the public site this is usually just your domain(s).
# Use "*" only for local/dev. Example: https://club.example.com,https://www.example.com
CORS_ORIGIN=*

# ─── HTTPS / Proxy ──────────────────────────────────
# Set to "true" if a reverse proxy (nginx, Cloudflare, etc.) terminates TLS
# and sets X-Forwarded-* headers. Enables secure cookies + proxy trust.
HTTPS=true

# OPTIONAL direct TLS: if you want the Node process to serve HTTPS itself
# (instead of a proxy), set HTTPS_DIRECT=true and provide the two paths below.
HTTPS_DIRECT=false
TLS_KEY_PATH=
TLS_CERT_PATH=

# ─── Database ──────────────────────────────────
# DB_TYPE: "postgres" (Render managed PostgreSQL) or "sqlite" (local dev).
# On Render, leave DB_TYPE unset (auto = postgres in production) and let
# Render inject DATABASE_URL from the attached PostgreSQL instance.
DB_TYPE=sqlite
# SQLite file path (local dev only).
DB_PATH=./data/club.db
# PostgreSQL connection string (Render injects this automatically via the
# attached database; set manually only for external/self-hosted Postgres).
DATABASE_URL=

# ─── Uploads / Media storage ──────────────────────────
# STORAGE_TYPE: "r2" (Cloudflare R2, free) or "local" (dev).
# On Render, set STORAGE_TYPE=r2 and provide the R2_* values below
# so uploaded images persist (Render Free has no persistent disk).
STORAGE_TYPE=local
UPLOAD_PATH=./uploads
# Max upload size in bytes (5 MB default). Raise cautiously.
MAX_FILE_SIZE=5242880

# ─── Cloudflare R2 (S3-compatible) — production media storage ───
# Create a free R2 bucket, enable public access, and paste the values:
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# ─── Logging ──────────────────────────────────
# One of: error, warn, info, debug
LOG_LEVEL=info
# Directory for log files (created automatically).
LOG_DIR=./logs
