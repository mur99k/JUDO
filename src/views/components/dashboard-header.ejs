<header class="dashboard-header">
  <button class="dashboard-toggle" id="sidebarToggle" aria-label="فتح القائمة">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>
  <div class="dashboard-header-title">
    <h1><%= typeof title !== 'undefined' ? title : '' %></h1>
  </div>
  <div class="dashboard-header-user">
    <span class="dashboard-user-name"><%= typeof user !== 'undefined' && user ? user.name : '' %></span>
    <span class="dashboard-user-role"><%= typeof user !== 'undefined' && user ? (user.role === 'admin' ? 'مدير' : 'مدرب') : '' %></span>
  </div>
</header>
