<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <% if (typeof hideLogo === 'undefined' || !hideLogo) { %><img src="/logo/logo.png" alt="نادي الريادة للجودو" class="sidebar-logo" width="40" height="40"><% } %>
    <div class="sidebar-info">
      <div class="sidebar-app-name">نادي الريادة للجودو</div>
      <div class="sidebar-app-sub">لوحة التحكم</div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="sidebar-section">القائمة الرئيسية</div>
    <a href="/dashboard" class="sidebar-link <%= activePage === 'overview' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      لوحة التحكم
    </a>
    <a href="/dashboard/students" class="sidebar-link <%= activePage === 'students' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      الطلاب
    </a>
    <a href="/dashboard/coaches" class="sidebar-link <%= activePage === 'coaches' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
      المدربون
    </a>
    <a href="/dashboard/attendance" class="sidebar-link <%= activePage === 'attendance' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      الحضور
    </a>
    <a href="/dashboard/subscriptions" class="sidebar-link <%= activePage === 'subscriptions' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      الاشتراكات
    </a>

    <div class="sidebar-section">التقارير</div>
    <a href="/dashboard/reports" class="sidebar-link <%= activePage === 'reports' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
      التقارير
    </a>
    <a href="/dashboard/gallery" class="sidebar-link <%= activePage === 'gallery' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      معرض الصور
    </a>

    <div class="sidebar-section">الإعدادات</div>
    <a href="/dashboard/settings" class="sidebar-link <%= activePage === 'settings' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.32 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      الإعدادات
    </a>
    <a href="/dashboard/profile" class="sidebar-link <%= activePage === 'profile' ? 'active' : '' %>">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      الملف الشخصي
    </a>
  </nav>

  <div class="sidebar-footer">
    <form action="/api/auth/logout" method="POST" id="logoutForm">
      <button type="submit" class="sidebar-logout">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        تسجيل الخروج
      </button>
    </form>
  </div>
</aside>

<div class="sidebar-overlay" id="sidebarOverlay"></div>
