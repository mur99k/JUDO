<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>لوحة التحكم - نادي الريادة للجودو</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/tokens.css?v=3">
  <link rel="stylesheet" href="/styles/base.css?v=3">
  <link rel="stylesheet" href="/styles/components/buttons.css?v=3">
  <link rel="stylesheet" href="/styles/components/forms.css?v=3">
  <link rel="stylesheet" href="/styles/components/modal.css?v=3">
  <link rel="stylesheet" href="/styles/components/toast.css?v=3">
  <link rel="stylesheet" href="/styles/utilities/animations.css?v=3">
  <link rel="stylesheet" href="/styles/pages/dashboard.css?v=3">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <%- typeof headExtra !== 'undefined' ? headExtra : '' %>
</head>
<body>
  <div class="dash-wrap">
    <!-- Sidebar -->
    <aside class="dash-sidebar" id="dashSidebar">
      <div class="dash-sidebar-head">
        <a href="/dashboard" class="dash-sidebar-logo">
          <img src="/logo/logo.png" alt="نادي الريادة للجودو" width="36" height="36">
          <span>نادي الريادة</span>
        </a>
        <button class="dash-sidebar-close" id="dashSidebarClose" aria-label="إغلاق">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <nav class="dash-sidebar-nav">
        <div class="dash-nav-section">القائمة الرئيسية</div>
        <a href="/dashboard" class="dash-nav-link <%= activePage === 'overview' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
          <span>لوحة التحكم</span>
        </a>
        <a href="/dashboard/students" class="dash-nav-link <%= activePage === 'students' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          <span>الطلاب</span>
        </a>
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
        <a href="/dashboard/coaches" class="dash-nav-link <%= activePage === 'coaches' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
          <span>المدربون</span>
        </a>
        <% } %>
        <a href="/dashboard/attendance" class="dash-nav-link <%= activePage === 'attendance' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 16v1a2 2 0 01-2 2H3a2 2 0 01-2-2V7a2 2 0 012-2h2m5-2h10a2 2 0 012 2v10a2 2 0 01-2 2h-1"/><polyline points="15 11 18 14 22 10"/><rect x="3" y="3" width="7" height="7"/></svg>
          <span>الحضور</span>
        </a>
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
        <a href="/dashboard/subscriptions" class="dash-nav-link <%= activePage === 'subscriptions' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          <span>الاشتراكات</span>
        </a>
        <a href="/dashboard/reports" class="dash-nav-link <%= activePage === 'reports' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          <span>التقارير</span>
        </a>
        <% } %>
        <a href="/dashboard/gallery" class="dash-nav-link <%= activePage === 'gallery' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>معرض الصور</span>
        </a>

        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
        <div class="dash-nav-section">الإعدادات</div>
        <a href="/dashboard/settings" class="dash-nav-link <%= activePage === 'settings' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <span>الإعدادات</span>
        </a>
        <% } %>
        <a href="/dashboard/profile" class="dash-nav-link <%= activePage === 'profile' ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>الملف الشخصي</span>
        </a>
      </nav>

      <div class="dash-sidebar-foot">
        <form id="logoutForm" method="POST" action="/api/auth/logout" style="width:100%;">
          <button type="submit" class="dash-logout-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            <span>تسجيل الخروج</span>
          </button>
        </form>
      </div>
    </aside>
    <div class="dash-sidebar-overlay" id="dashOverlay"></div>

    <!-- Main area -->
    <div class="dash-main">
      <!-- Header -->
      <header class="dash-header" id="dashHeader">
        <div class="dash-header-left">
          <button class="dash-hamburger" id="dashHamburger" aria-label="فتح القائمة">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <nav class="dash-breadcrumb">
            <% if (typeof breadcrumbs !== 'undefined') { breadcrumbs.forEach(function(cr, i) { %>
              <% if (i < breadcrumbs.length - 1) { %><a href="<%= cr.url %>"><%= cr.label %></a> <% } else { %><span><%= cr.label %></span><% } %>
            <% }); } else { %>
              <span><%= typeof title !== 'undefined' ? title : 'لوحة التحكم' %></span>
            <% } %>
          </nav>
        </div>
        <div class="dash-header-right">
          <div class="dash-user-badge">
            <div class="dash-user-avatar"><%= typeof user !== 'undefined' && user ? user.name.charAt(0) : '?' %></div>
            <div class="dash-user-meta">
              <span class="dash-user-name"><%= typeof user !== 'undefined' && user ? user.name : '' %></span>
              <span class="dash-user-role"><%= typeof user !== 'undefined' && user ? (user.role === 'admin' ? 'مدير' : 'مدرب') : '' %></span>
            </div>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="dash-content" id="dashContent">
        <%- body %>
      </div>
    </div>
  </div>

  <%- include('../components/toast-container') %>

  <script>window.__userRole = '<%= typeof user !== 'undefined' && user ? user.role : '' %>';</script>
  <script src="/scripts/modules/api.js?v=3"></script>
  <script src="/scripts/modules/toast.js?v=3"></script>
  <script src="/scripts/modules/modal.js?v=3"></script>
  <script src="/scripts/pages/dashboard/dashboard.js?v=3"></script>
  <script src="/scripts/pages/dashboard/overview.js?v=3"></script>
  <script src="/scripts/pages/dashboard/students.js?v=3"></script>
  <script src="/scripts/pages/dashboard/coaches.js?v=3"></script>
  <script src="/scripts/pages/dashboard/attendance.js?v=3"></script>
  <script src="/scripts/pages/dashboard/subscriptions.js?v=3"></script>
  <script src="/scripts/pages/dashboard/reports.js?v=3"></script>
  <script src="/scripts/pages/dashboard/gallery.js?v=3"></script>
  <script src="/scripts/pages/dashboard/settings.js?v=3"></script>
  <script src="/scripts/pages/dashboard/profile.js?v=3"></script>
  <script src="/scripts/pages/dashboard/coach.js?v=3"></script>
  <script src="/scripts/pages/dashboard/student-report.js?v=3"></script>
</body>
</html>