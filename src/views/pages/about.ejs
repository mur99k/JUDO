<% activePage = 'about'; %>

<section class="section" style="padding-top:100px;">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">عن النادي</span>
      <h2 class="section-title">نادي الريادة للجودو</h2>
      <div class="section-divider"></div>
    </div>
  </div>
</section>

<!-- Row 1: Text Right / Image Left -->
<section class="section section-alt" style="padding-top:0;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;">
      <div style="border-radius:20px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 12px 32px rgba(27,47,79,0.12);">
        <% if (typeof photos !== 'undefined' && photos.length > 0) { %>
        <img src="<%= photos[0].url %>" alt="" onerror="this.onerror=null;this.style.display='none';" style="width:100%;height:100%;object-fit:cover;">
        <% } %>
      </div>
      <div>
        <h3 style="font-size:1.5rem;font-weight:800;color:var(--color-navy);margin-bottom:12px;">رؤيتنا</h3>
        <p style="font-size:0.95rem;line-height:1.9;color:var(--text-soft);">أن نكون النادي الرائد في تدريب ونشر رياضة الجودو في المملكة العربية السعودية، وبناء جيل من الأبطال يتميزون بالقيم الرياضية والانضباط والتفوق.</p>
      </div>
    </div>
  </div>
</section>

<!-- Row 2: Text Left / Image Right -->
<section class="section" style="padding-top:0;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;">
      <div>
        <h3 style="font-size:1.5rem;font-weight:800;color:var(--color-navy);margin-bottom:12px;">رسالتنا</h3>
        <p style="font-size:0.95rem;line-height:1.9;color:var(--text-soft);">تقديم تدريب عالي الجودة في بيئة آمنة ومحفزة، مع غرس قيم الاحترام والانضباط والثقة في نفوس اللاعبين. نسعى لتطوير مهارات اللاعبين البدنية والذهنية.</p>
      </div>
      <div style="border-radius:20px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 12px 32px rgba(27,47,79,0.12);">
        <% if (typeof photos !== 'undefined' && photos.length > 1) { %>
        <img src="<%= photos[1].url %>" alt="" onerror="this.onerror=null;this.style.display='none';" style="width:100%;height:100%;object-fit:cover;">
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Row 3: Image Left / Text Right -->
<section class="section section-alt" style="padding-top:0;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;">
      <div style="border-radius:20px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 12px 32px rgba(27,47,79,0.12);">
        <% if (typeof photos !== 'undefined' && photos.length > 2) { %>
        <img src="<%= photos[2].url %>" alt="" onerror="this.onerror=null;this.style.display='none';" style="width:100%;height:100%;object-fit:cover;">
        <% } %>
      </div>
      <div>
        <h3 style="font-size:1.5rem;font-weight:800;color:var(--color-navy);margin-bottom:12px;">أهدافنا</h3>
        <ul style="display:flex;flex-direction:column;gap:10px;">
          <li style="display:flex;gap:8px;font-size:0.95rem;color:var(--text-soft);"><span style="color:var(--color-gold);flex-shrink:0;">✦</span> نشر ثقافة الجودو وفنون الدفاع عن النفس في المجتمع السعودي</li>
          <li style="display:flex;gap:8px;font-size:0.95rem;color:var(--text-soft);"><span style="color:var(--color-gold);flex-shrink:0;">✦</span> اكتشاف المواهب الشابة وصقلها للوصول إلى المستويات التنافسية</li>
          <li style="display:flex;gap:8px;font-size:0.95rem;color:var(--text-soft);"><span style="color:var(--color-gold);flex-shrink:0;">✦</span> تعزيز قيم الانضباط والاحترام والروح الرياضية</li>
          <li style="display:flex;gap:8px;font-size:0.95rem;color:var(--text-soft);"><span style="color:var(--color-gold);flex-shrink:0;">✦</span> المشاركة في البطولات المحلية والدولية وتمثيل المملكة</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Photo Grid 2x2 -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">معرض</span>
      <h2 class="section-title">صور من النادي</h2>
      <div class="section-divider"></div>
    </div>
    <div style="text-align:center;padding:40px 0;color:var(--text-muted);">
      سيتم إضافة صور النادي قريباً
    </div>
  </div>
</section>
