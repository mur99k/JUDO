<% activePage = 'contact'; %>

<section class="section" style="padding-top:100px;">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">نحن هنا لمساعدتك</span>
      <h2 class="section-title">تواصل <span style="color:var(--color-gold);">معنا</span></h2>
      <div class="section-divider"></div>
      <p style="margin-top:16px;color:var(--text-soft);">لديك استفسار أو تريد الانضمام للنادي؟ تواصل معنا.</p>
    </div>

    <!-- 3 cards: stacked on mobile, row on desktop -->
    <div class="contact-grid-3">
      <a href="https://wa.me/966598199304" target="_blank" class="card contact-card-plain">
        <div class="contact-icon-lg" style="background:#DCFCE7;">💬</div>
        <h3 style="font-weight:700;margin-bottom:4px;">واتساب</h3>
        <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:8px;">+966 59 819 9304</p>
        <span style="font-size:0.8rem;color:var(--color-navy-light);font-weight:600;">اضغط للتواصل</span>
      </a>
      <a href="tel:+966567383104" class="card contact-card-plain">
        <div class="contact-icon-lg" style="background:#DBEAFE;">📞</div>
        <h3 style="font-weight:700;margin-bottom:4px;">اتصال</h3>
        <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:8px;">+966 56 738 3104</p>
        <span style="font-size:0.8rem;color:var(--color-navy-light);font-weight:600;">اضغط للاتصال</span>
      </a>
      <div class="card contact-card-plain">
        <div class="contact-icon-lg" style="background:var(--color-blue-soft);">📍</div>
        <h3 style="font-weight:700;margin-bottom:4px;">موقع النادي</h3>
        <p style="font-size:0.82rem;color:var(--text-muted);">جدة، المملكة العربية السعودية</p>
      </div>
      <div class="card contact-card-plain">
        <div class="contact-icon-lg" style="background:var(--color-gold-soft);">🕐</div>
        <h3 style="font-weight:700;margin-bottom:4px;">أوقات التدريب</h3>
        <p style="font-size:0.82rem;color:var(--text-muted);">استعلام عبر واتساب</p>
      </div>
    </div>

    <!-- Info + Form: stacked on mobile, side by side on desktop -->
    <div class="contact-split">
      <div class="card" style="padding:20px;">
        <h3 style="font-size:0.95rem;font-weight:700;color:var(--color-navy);margin-bottom:14px;">📞 معلومات الاتصال</h3>
        <div style="display:flex;flex-direction:column;gap:8px;">
          <div class="contact-info-row" style="padding:8px 12px;gap:10px;">
            <span style="font-size:16px;">💬</span>
            <div><div style="font-size:0.72rem;color:var(--text-muted);">واتساب</div><a href="https://wa.me/966598199304" target="_blank" style="font-weight:600;font-size:0.88rem;direction:ltr;unicode-bidi:isolate;text-align:right;text-decoration:none;color:var(--color-navy);">+966 59 819 9304</a></div>
          </div>
          <div class="contact-info-row" style="padding:8px 12px;gap:10px;">
            <span style="font-size:16px;">📞</span>
            <div><div style="font-size:0.72rem;color:var(--text-muted);">اتصال</div><a href="tel:+966567383104" style="font-weight:600;font-size:0.88rem;direction:ltr;unicode-bidi:isolate;text-align:right;text-decoration:none;color:var(--color-navy);">+966 56 738 3104</a></div>
          </div>
          <div class="contact-info-row" style="padding:8px 12px;gap:10px;">
            <span style="font-size:16px;">📍</span>
            <div><div style="font-size:0.72rem;color:var(--text-muted);">الموقع</div><div style="font-weight:600;font-size:0.88rem;">جدة، المملكة العربية السعودية</div></div>
          </div>
        </div>
      </div>
      <div class="card" style="padding:20px;">
        <h3 style="font-size:0.95rem;font-weight:700;color:var(--color-navy);margin-bottom:14px;">💬 أرسل رسالة</h3>
        <form id="contactForm" style="display:flex;flex-direction:column;gap:10px;">
          <input type="text" name="name" required placeholder="الاسم" class="contact-input">
          <input type="tel" name="phone" placeholder="الجوال" class="contact-input">
          <textarea name="message" rows="3" required placeholder="رسالتك..." class="contact-input" style="resize:vertical;"></textarea>
          <button type="submit" class="btn btn-accent btn-sm" style="align-self:flex-start;">إرسال</button>
        </form>
      </div>
    </div>

    <!-- Map -->
    <div class="map-frame" style="margin-top:32px;">
      <div style="position:absolute;top:12px;right:12px;z-index:1;background:rgba(27,47,79,0.85);backdrop-filter:blur(8px);padding:8px 14px;border-radius:10px;color:white;">
        <div style="font-weight:700;font-size:0.85rem;">📍 موقع النادي</div>
        <div style="font-size:0.72rem;opacity:0.7;">جدة، المملكة العربية السعودية</div>
      </div>
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d500!2d39.1820!3d21.5269!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x15c3d1539bddad43%3A0xc23cc20d992a2115!2z2KPZhtmK2KfZhiDYp9mE2YTYp9mF2YjZhNin2YUgLSjYp9mE2KrYp9mE2LHYpyDYp9mE2LPZitin2YLZKSAtINmI2LHZg9iyINin2YTYqtin2YTYsdinINin2YTYs9mK2KfZgtip!5e0!3m2!1sar!2ssa!4v1" width="100%" height="350" allowfullscreen="" loading="lazy" title="خريطة موقع نادي الريادة للجودو"></iframe>
    </div>
  </div>
</section>


