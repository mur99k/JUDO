<% activePage = 'attendance'; %>

<div class="page-header">
  <h2>الحضور</h2>
  <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
    <span id="arabicDate" style="font-size:0.95rem;color:var(--color-navy);font-weight:600;background:var(--color-blue-soft);padding:8px 12px;border-radius:8px;"></span>
    <input type="text" class="form-input" id="attendanceDate" placeholder="اختر التاريخ الهجري" style="max-width:200px;cursor:pointer;">
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card"><div class="stat-icon green"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div class="stat-body"><span class="stat-label">حاضر</span><span class="stat-value" id="statPresent">0</span></div></div>
  <div class="stat-card"><div class="stat-icon red"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div><div class="stat-body"><span class="stat-label">غائب</span><span class="stat-value" id="statAbsent">0</span></div></div>
  <div class="stat-card"><div class="stat-icon gold"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div><div class="stat-body"><span class="stat-label">معذر</span><span class="stat-value" id="statExcused">0</span></div></div>
  <div class="stat-card"><div class="stat-icon blue"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div><div class="stat-body"><span class="stat-label">الإجمالي</span><span class="stat-value" id="statTotal">0</span></div></div>
</div>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th style="text-align:right;">اسم الطالب</th>
        <th style="text-align:center;">الحالة</th>
        <th style="text-align:center;width:60px;">تقرير</th>
      </tr>
    </thead>
    <tbody id="attendanceBody">
      <tr><td colspan="4" class="table-empty">جاري التحميل...</td></tr>
    </tbody>
  </table>
</div>

<div style="display:flex;justify-content:flex-end;margin-top:16px;">
  <button class="btn btn-primary" id="saveAttendanceBtn">حفظ الحضور</button>
</div>