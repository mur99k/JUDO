<% activePage = 'overview'; %>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
    </div>
    <div class="stat-body">
      <span class="stat-label">إجمالي الطلاب</span>
      <span class="stat-value" id="statTotalStudents">0</span>
    </div>
  </div>
  <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
    </div>
    <div class="stat-body">
      <span class="stat-label">اشتراكات نشطة</span>
      <span class="stat-value" id="statActiveSubs">0</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon gold">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
    </div>
    <div class="stat-body">
      <span class="stat-label">المدربون</span>
      <span class="stat-value" id="statCoaches">0</span>
    </div>
  </div>
  <% } %>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </div>
    <div class="stat-body">
      <span class="stat-label">الحضور اليوم</span>
      <span class="stat-value" id="statTodayAttendance">0</span>
    </div>
  </div>
</div>

<!-- Two-column layout -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px;">
  <!-- Recent students -->
  <div class="dash-card">
    <div class="dash-card-header">
      <h3 class="dash-card-title">أحدث الطلاب</h3>
      <a href="/dashboard/students" style="font-size:0.8rem;color:var(--color-navy);font-weight:600;text-decoration:none;">عرض الكل</a>
    </div>
    <div class="dash-card-body" id="recentStudentsList">
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        <h3>لا يوجد طلاب</h3>
        <p>سجل أول طالب في النادي</p>
      </div>
    </div>
  </div>

  <!-- Quick actions -->
  <div class="dash-card">
    <div class="dash-card-header">
      <h3 class="dash-card-title">إجراءات سريعة</h3>
    </div>
    <div class="dash-card-body" style="display:flex;flex-direction:column;gap:10px;">
      <a href="/dashboard/students" class="quick-action">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        إضافة طالب جديد
      </a>
      <a href="/dashboard/attendance" class="quick-action">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 16v1a2 2 0 01-2 2H3a2 2 0 01-2-2V7a2 2 0 012-2h2m5-2h10a2 2 0 012 2v10a2 2 0 01-2 2h-1"/><polyline points="15 11 18 14 22 10"/><rect x="3" y="3" width="7" height="7"/></svg>
        تسجيل حضور اليوم
      </a>
      <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
      <a href="/dashboard/subscriptions" class="quick-action">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        إضافة اشتراك
      </a>
      <a href="/dashboard/coaches" class="quick-action">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
        إدارة المدربين
      </a>
      <% } %>
    </div>
  </div>
</div>

<!-- Alerts -->
<div class="dash-card" id="alertsCard">
  <div class="dash-card-header">
    <h3 class="dash-card-title">تنبيهات</h3>
  </div>
  <div class="dash-card-body" id="alertsList">
    <div class="alert alert-info">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      <span>مرحباً بك في لوحة التحكم. ابدأ بإضافة الطلاب والاشتراكات.</span>
    </div>
  </div>
</div>