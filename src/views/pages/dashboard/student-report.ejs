<% activePage = 'attendance'; %>
<script>window.__studentId = '<%= typeof studentId !== "undefined" ? studentId : "" %>'; window.__studentMonth = '<%= typeof month !== "undefined" ? month : "" %>'; window.__studentYear = '<%= typeof year !== "undefined" ? year : "" %>';</script>

<div class="page-header">
  <h2 id="reportTitle">تقرير طالب</h2>
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
    <span style="font-size:0.85rem;color:var(--text-muted);">الشهر الهجري:</span>
    <div class="custom-select" id="srHijriMonthSelect" style="width:160px;">
      <div class="custom-select-trigger" onclick="toggleCustomSelect('srHijriMonthSelect')">
        <span class="custom-select-text" id="srHijriMonthText">محرم</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="custom-select-options" id="srHijriMonthOptions"></div>
    </div>
    <div class="custom-select" id="srHijriYearSelect" style="width:130px;">
      <div class="custom-select-trigger" onclick="toggleCustomSelect('srHijriYearSelect')">
        <span class="custom-select-text" id="srHijriYearText">1447 هـ</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="custom-select-options" id="srHijriYearOptions"></div>
    </div>
    <input type="hidden" id="srHijriMonth" value="1">
    <input type="hidden" id="srHijriYear" value="1447">
  </div>
</div>

<div class="stats-grid" style="margin-bottom:16px;">
  <div class="stat-card"><div class="stat-icon green"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div class="stat-body"><span class="stat-label">حاضر</span><span class="stat-value" id="srPresent">-</span></div></div>
  <div class="stat-card"><div class="stat-icon red"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div><div class="stat-body"><span class="stat-label">غائب</span><span class="stat-value" id="srAbsent">-</span></div></div>
  <div class="stat-card"><div class="stat-icon gold"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div><div class="stat-body"><span class="stat-label">معذر</span><span class="stat-value" id="srExcused">-</span></div></div>
  <div class="stat-card"><div class="stat-icon blue"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div><div class="stat-body"><span class="stat-label">نسبة الحضور</span><span class="stat-value" id="srRate">-</span></div></div>
</div>

<div class="dash-card" style="overflow:hidden;">
  <div class="dash-card-header">
    <h3 class="dash-card-title" id="srStudentName">—</h3>
    <span style="font-size:0.82rem;color:var(--text-muted);" id="srMonthLabel"></span>
  </div>
  <div style="overflow-x:auto;" id="srTableWrap">
    <table style="width:100%;border-collapse:collapse;min-width:500px;">
      <thead><tr><th style="text-align:center;padding:10px 8px;font-size:0.78rem;color:#718096;background:#f8fafc;border-bottom:2px solid #e9edf2;">اليوم</th><th style="text-align:center;padding:10px 8px;font-size:0.78rem;color:#718096;background:#f8fafc;border-bottom:2px solid #e9edf2;">التاريخ</th><th style="text-align:center;padding:10px 8px;font-size:0.78rem;color:#718096;background:#f8fafc;border-bottom:2px solid #e9edf2;">الحالة</th></tr></thead>
      <tbody id="srTableBody"><tr><td colspan="3" style="text-align:center;padding:30px;color:#a0aec0;">جاري التحميل...</td></tr></tbody>
    </table>
  </div>
</div>

<style>
.custom-select {
  position: relative;
  width: 100%;
}
.custom-select-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px;
  background: #fff;
  border: 1.5px solid #e2e8f0;
  border-radius: 12px;
  cursor: pointer;
  font-family: var(--font-primary);
  font-size: 0.95rem;
  color: var(--color-navy);
  transition: all 0.2s;
}
.custom-select-trigger:hover {
  border-color: var(--color-navy);
}
.custom-select.open .custom-select-trigger {
  border-color: var(--color-navy);
  box-shadow: 0 0 0 3px rgba(27,47,79,0.1);
}
.custom-select-text {
  flex: 1;
  text-align: right;
}
.custom-select svg {
  width: 16px;
  height: 16px;
  color: #94a3b8;
  transition: transform 0.2s;
  flex-shrink: 0;
}
.custom-select.open svg {
  transform: rotate(180deg);
}
.custom-select-options {
  position: absolute;
  top: 100%;
  right: 0;
  left: 0;
  margin-top: 4px;
  background: #fff;
  border: 1.5px solid #e2e8f0;
  border-radius: 12px;
  box-shadow: 0 8px 24px rgba(27,47,79,0.12);
  z-index: 1000;
  max-height: 300px;
  overflow-y: auto;
  display: none;
}
.custom-select.open .custom-select-options {
  display: block;
}
.custom-select-option {
  padding: 10px 14px;
  cursor: pointer;
  font-family: var(--font-primary);
  font-size: 0.9rem;
  color: var(--color-navy);
  transition: background 0.15s;
}
.custom-select-option:hover {
  background: #f8fafc;
}
.custom-select-option.active {
  background: var(--color-blue-soft);
  color: var(--color-navy);
  font-weight: 600;
}

.sr-day-row { border-bottom: 1px solid #f0f2f5; }
.sr-day-row td { padding: 8px 10px; text-align: center; font-size: 0.85rem; }
.sr-day-num { font-weight: 600; color: var(--text-soft); }
.sr-day-date { color: var(--text-muted); font-size: 0.8rem; }
.sr-day-status { font-weight: 700; }
.sr-day-status.present { color: #059669; background: #ecfdf5; }
.sr-day-status.absent { color: #dc2626; background: #fef2f2; }
.sr-day-status.excused { color: #b8860b; background: #fffbeb; }
.sr-day-status.none { color: #cbd5e1; }
</style>
