<% activePage = 'login'; %>

<section class="section" style="padding-top:100px;min-height:100vh;display:flex;align-items:center;">
  <div class="container">
    <div class="card reveal" style="max-width:440px;margin:0 auto;padding:32px;">
      <div style="text-align:center;margin-bottom:24px;">
        <img src="/logo/logo.png" alt="نادي الريادة للجودو" style="width:72px;height:72px;border-radius:16px;margin-bottom:12px;">
        <h2 style="font-size:1.4rem;font-weight:800;color:var(--color-navy);">تسجيل الدخول</h2>
        <p style="font-size:0.9rem;color:var(--text-soft);">أدخل بياناتك للوصول إلى حسابك</p>
      </div>

      <div id="errorDisplay" class="auth-error" style="display:none;background:var(--danger-soft);color:var(--danger);padding:10px 14px;border-radius:8px;font-size:0.85rem;margin-bottom:16px;text-align:center;"></div>

      <div class="auth-tabs" style="display:flex;gap:0;margin-bottom:24px;border-radius:10px;overflow:hidden;border:1px solid var(--gray-200);">
        <button type="button" class="auth-tab" id="tabStudent" style="flex:1;padding:10px;border:none;cursor:pointer;font-weight:600;font-size:0.85rem;background:var(--color-navy);color:white;">طالب</button>
        <button type="button" class="auth-tab" id="tabAdmin" style="flex:1;padding:10px;border:none;cursor:pointer;font-weight:600;font-size:0.85rem;background:var(--gray-50);color:var(--text-muted);">مدير / مدرب</button>
      </div>

      <form id="studentLoginForm" class="form auth-form" novalidate>
        <div class="form-group">
          <label class="form-label">رقم الهوية</label>
          <input type="text" class="form-input" name="nationalId" required inputmode="numeric" pattern="\d{10}" maxlength="10" placeholder="أدخل رقم الهوية (10 أرقام)">
        </div>
        <button type="submit" class="btn btn-accent w-full" style="margin-top:8px;"><span class="btn-text">دخول</span></button>
      </form>

      <form id="adminLoginForm" class="form auth-form" novalidate style="display:none;">
        <div class="form-group">
          <label class="form-label">البريد الإلكتروني</label>
          <input type="email" class="form-input" name="email" required placeholder="أدخل البريد الإلكتروني">
        </div>
        <div class="form-group">
          <label class="form-label">كلمة المرور</label>
          <input type="password" class="form-input" name="password" required placeholder="أدخل كلمة المرور">
        </div>
        <button type="submit" class="btn btn-accent w-full" style="margin-top:8px;"><span class="btn-text">دخول</span></button>
      </form>

      <p style="text-align:center;margin-top:20px;padding-top:16px;border-top:1px solid var(--gray-100);font-size:0.85rem;color:var(--text-soft);">ليس لديك حساب؟ <a href="/register" style="color:var(--color-navy);font-weight:600;">سجل الآن</a></p>
    </div>
  </div>
</section>
