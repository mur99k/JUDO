<% activePage = 'register'; %>

<section class="section" style="padding-top:100px;min-height:100vh;display:flex;align-items:center;">
  <div class="container">
    <div class="card reveal" style="max-width:560px;margin:0 auto;padding:32px;">
      <div style="text-align:center;margin-bottom:24px;">
        <% if (typeof hideLogo === 'undefined' || !hideLogo) { %><img src="/logo/logo.png" alt="<%= hideLogo ? 'جودو' : 'نادي الريادة للجودو' %>" style="width:72px;height:72px;border-radius:16px;margin-bottom:12px;"><% } %>
        <h2 style="font-size:1.4rem;font-weight:800;color:var(--color-navy);">تسجيل مشترك جديد</h2>
        <p style="font-size:0.9rem;color:var(--text-soft);"><%= hideLogo ? 'انضم إلى عائلة جودو' : 'انضم إلى عائلة نادي الريادة للجودو' %></p>
      </div>

      <div id="registerError" style="display:none;background:var(--danger-soft);color:var(--danger);padding:10px 14px;border-radius:8px;font-size:0.85rem;margin-bottom:16px;text-align:center;"></div>

      <form id="registerForm" class="form" novalidate style="display:flex;flex-direction:column;gap:16px;">
        <div style="display:grid;grid-template-columns:1fr;gap:16px;">
          <div class="form-group">
            <label class="form-label">الاسم الثلاثي <span style="color:var(--danger);">*</span></label>
            <input type="text" class="form-input" name="fullName" required placeholder="مثال: أحمد محمد الخالدي">
          </div>
          <div class="form-group">
            <label class="form-label">رقم الهوية <span style="color:var(--danger);">*</span></label>
            <input type="text" class="form-input" name="nationalId" required inputmode="numeric" pattern="\d{10}" maxlength="10" placeholder="10 أرقام">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div class="form-group">
            <label class="form-label">العمر <span style="color:var(--danger);">*</span></label>
            <input type="number" class="form-input" name="age" required min="3" max="100" placeholder="العمر">
          </div>
          <div class="form-group">
            <label class="form-label">رقم الجوال <span style="color:var(--text-muted);font-weight:400;font-size:0.8rem;">(اختياري)</span></label>
            <input type="tel" class="form-input" name="phone" placeholder="05xxxxxxxx">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">رقم ولي الأمر <span style="color:var(--text-muted);font-weight:400;font-size:0.8rem;">(اختياري)</span></label>
          <input type="tel" class="form-input" name="parentPhone" placeholder="05xxxxxxxx">
        </div>
        <input type="hidden" name="password" value="">
        <div class="form-group">
          <div style="display:grid;grid-template-columns:1fr auto;gap:20px;align-items:center;">
            <div style="text-align:right;">
              <label class="form-label" style="display:block;margin-bottom:6px;">الصورة الشخصية <span style="color:var(--text-muted);font-weight:400;font-size:0.8rem;">(اختياري)</span></label>
              <p style="font-size:0.85rem;color:var(--text-soft);line-height:1.6;">يمكنك رفع صورة شخصية واضحة للاعب. هذه الخطوة اختيارية ويمكن إضافتها لاحقاً.</p>
            </div>
            <label class="photo-upload" for="regPhoto">
              <input type="file" id="regPhoto" name="photo" accept="image/*" hidden>
              <img id="regPhotoPreview" class="photo-preview" src="" alt="معاينة الصورة" style="display:none;">
              <div id="regPhotoPlaceholder" class="photo-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>اضغط هنا</span>
              </div>
            </label>
          </div>
        </div>
        <div id="regCropArea" style="display:none;">
          <div style="position:relative;max-height:250px;overflow:hidden;border-radius:12px;background:#f0f0f0;">
            <img id="regCropImage" src="" alt="" style="max-width:100%;">
          </div>
          <div style="display:flex;align-items:center;gap:12px;margin-top:8px;justify-content:center;">
            <button type="button" id="regCropZoomOut" style="background:var(--gray-100);border:none;border-radius:50%;width:32px;height:32px;font-size:18px;cursor:pointer;">−</button>
            <input type="range" id="regCropZoomRange" min="0" max="1" step="0.01" value="0" style="flex:1;max-width:200px;">
            <button type="button" id="regCropZoomIn" style="background:var(--gray-100);border:none;border-radius:50%;width:32px;height:32px;font-size:18px;cursor:pointer;">+</button>
            <button type="button" id="regCropConfirm" class="btn btn-accent btn-sm" style="padding:6px 16px;">تأكيد</button>
            <button type="button" id="regCropCancel" class="btn btn-outline btn-sm" style="padding:6px 16px;">إلغاء</button>
          </div>
        </div>
        <button type="submit" class="btn btn-accent w-full"><span class="btn-text">تسجيل</span></button>
      </form>

      <p style="text-align:center;margin-top:20px;padding-top:16px;border-top:1px solid var(--gray-100);font-size:0.85rem;color:var(--text-soft);">لديك حساب بالفعل؟ <a href="/login" style="color:var(--color-navy);font-weight:600;">تسجيل دخول</a></p>
    </div>
  </div>
</section>
