<% activePage = 'student'; %>

<section style="padding:96px 0 60px;">
  <div class="container">
    <div id="studentDashboard" style="display:flex;flex-direction:column;gap:14px;">
      <div class="skeleton-card" style="height:200px;"></div>
    </div>
  </div>
</section>

<div class="modal-overlay" id="editStudentModal">
  <div class="modal">
    <div class="modal-header">
      <h2 class="modal-title">تعديل بياناتي</h2>
      <button class="modal-close" onclick="Modal.close('editStudentModal')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <form id="editStudentForm" class="form" novalidate>
        <div style="text-align:center;margin-bottom:12px;">
          <label class="photo-upload" for="editPhotoInput" style="width:100px;height:100px;cursor:pointer;">
            <input type="file" id="editPhotoInput" name="photo" accept="image/*" hidden>
            <img id="editPhotoPreview" class="photo-preview" src="" alt="معاينة" style="display:none;">
            <div id="editPhotoPlaceholder" class="photo-placeholder">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span style="font-size:0.75rem;">تغيير الصورة</span>
            </div>
          </label>
        </div>

        <!-- Crop area (hidden by default) -->
        <div id="cropArea" style="display:none;margin-bottom:12px;">
          <div style="position:relative;max-height:250px;overflow:hidden;border-radius:12px;background:#f0f0f0;">
            <img id="cropImage" src="" alt="قص الصورة" style="max-width:100%;">
          </div>
          <div style="display:flex;align-items:center;gap:12px;margin-top:8px;justify-content:center;">
            <button type="button" id="cropZoomOut" style="background:var(--gray-100);border:none;border-radius:50%;width:32px;height:32px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;">−</button>
            <input type="range" id="cropZoomRange" min="0" max="1" step="0.01" value="0" style="flex:1;max-width:200px;">
            <button type="button" id="cropZoomIn" style="background:var(--gray-100);border:none;border-radius:50%;width:32px;height:32px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;">+</button>
            <button type="button" id="cropConfirm" class="btn btn-accent btn-sm" style="padding:6px 16px;">تأكيد</button>
            <button type="button" id="cropCancel" class="btn btn-outline btn-sm" style="padding:6px 16px;">إلغاء</button>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">الاسم</label>
          <input type="text" class="form-input" name="fullName" required>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div class="form-group">
            <label class="form-label">رقم الجوال</label>
            <input type="tel" class="form-input" name="phone">
          </div>
          <div class="form-group">
            <label class="form-label">ولي الأمر</label>
            <input type="tel" class="form-input" name="parentPhone">
          </div>
        </div>
        <div style="margin-top:8px;padding-top:12px;border-top:1px solid var(--gray-100);">
          <details style="font-size:0.85rem;">
            <summary style="cursor:pointer;color:var(--text-muted);font-weight:500;">تغيير كلمة المرور</summary>
            <div style="margin-top:10px;display:flex;flex-direction:column;gap:10px;">
              <input type="password" class="form-input" name="currentPassword" placeholder="كلمة المرور الحالية" style="font-size:0.85rem;">
              <input type="password" class="form-input" name="newPassword" minlength="6" placeholder="كلمة المرور الجديدة" style="font-size:0.85rem;">
            </div>
          </details>
        </div>
        <button type="submit" class="btn btn-primary w-full">حفظ</button>
      </form>
    </div>
  </div>
</div>
